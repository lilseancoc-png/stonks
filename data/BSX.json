34,"bars":151,"rsi":33.27,"macd":{"line":-1.6821,"signal":-2.0598,"hist":0.3777},"sr":{"s20":50.58,"r20":58.51,"s50":50.58,"r50":71.94},"volRegime":{"rv30":0.5673,"rv30Pctile":74,"samples":121},"volume":{"today":25491807,"avg20":17437070,"rvol":1.46,"priceMove1dPct":-10.93,"conviction":"mixed"}},"fundamentals":{"name":"Boston Scientific Corporation","longBusinessSummary":"Boston Scientific Corporation develops, manufactures, and markets medical devices for use in various interventional medical specialties worldwide. The company operates in two segments, MedSurg and Cardiovascular. It offers devices to diagnose and treat a range of gastrointestinal conditions, such as resolution clips, biliary stent systems, stents and electrocautery enhanced delivery systems, SpyGlass, single-use scopes used for diagnostic and therapeutic procedures in the pancreaticobiliary system, in endoscopic retrograde cholangiopancreatography procedures, and single-use duodenoscopes, as well as endoluminal surgery and infection prevention products; devices to treat urological conditions, including ureteral stents, catheters, baskets, guidewires, urinary and bowel dysfunction, sheaths, balloons, single-use digital flexible ureteroscopes, holmium laser systems, penile implants, artificial urinary sphincter, laser system, and hydrogel systems; and devices to treat neurological movement disorders and manage chronic pain, such as spinal cord stimulator systems, radiofrequency ablation, and intraosseous nerve ablation and deep brain stimulation systems. The company also provides technologies for diagnosing and treating a range of diseases and abnormalities of the heart; WATCHMAN FLX, a left atrial appendage closure (LAAC) device; and implantable devices that monitor the heart and deliver electricity to treat cardiac abnormalities, such as cardioverter and cardiac resynchronization therapy defibrillators, MRI S-ICD systems, cardiac resynchronization therapy pacemakers, remote patient management systems, insertable cardiac monitor systems, and remote cardiac monitoring systems. In addition, it offers diagnosis and treatment of rate and rhythm disorders of the heart; peripheral arterial and venous diseases; and products to diagnose and treat forms of cancer. The company was incorporated in 1979 and is headquartered in Marlborough, Massachusetts.","industry":"Medical Devices","sector":"Healthcare","marketCap":76324339712,"trailingPE":21.485353,"forwardPE":13.640045,"pegRatio":0.7,"priceToBook":2.9508102,"priceToSales":3.7025487,"profitMargin":17.294,"operatingMargin":20.603001000000003,"grossMargin":68.943,"returnOnEquity":14.661,"returnOnAssets":6.0749996,"revenueGrowthYoy":11.600000000000001,"earningsGrowthYoy":100,"earningsQuarterlyGrowthYoy":99,"debtToEquity":42.25,"currentRatio":1.9,"quickRatio":0.98,"freeCashFlow":2807124992,"operatingCashFlow":4341000192,"totalCash":1452999936,"totalDebt":11029000192,"revenue":20614000640,"dividendYield":null,"payoutRatio":0,"beta":0.623,"fiftyTwoWeekHigh":109.5,"fiftyTwoWeekLow":50.5801,"targetMeanPrice":83.46875,"targetHighPrice":106,"targetLowPrice":60,"recommendationKey":"strong_buy","numberOfAnalystOpinions":32,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":0.8,"epsEstimate":0.78722,"surprisePct":1.6199999999999999},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":0.75,"epsEstimate":0.72522,"surprisePct":3.42},{"date":"2025-09-30","period":"-3q","epsActual":0.75,"epsEstimate":0.71366,"surprisePct":5.09},{"date":"2025-12-31","period":"-2q","epsActual":0.8,"epsEstimate":0.78105,"surprisePct":2.4300002000000003},{"date":"2026-03-31","period":"-1q","epsActual":0.8,"epsEstimate":0.78722,"surprisePct":1.6199999999999999}],"revenueHistory":[{"date":"2025-03-31","value":4663000000},{"date":"2025-06-30","value":5061000000},{"date":"2025-09-30","value":5065000000},{"date":"2025-12-31","value":5286000000},{"date":"2026-03-31","value":5203000000}],"grossProfitHistory":[{"date":"2025-03-31","value":