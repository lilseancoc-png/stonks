 treat cardiac abnormalities, such as cardioverter and cardiac resynchronization therapy defibrillators, MRI S-ICD systems, cardiac resynchronization therapy pacemakers, remote patient management systems, insertable cardiac monitor systems, and remote cardiac monitoring systems. In addition, it offers diagnosis and treatment of rate and rhythm disorders of the heart; peripheral arterial and venous diseases; and products to diagnose and treat forms of cancer. The company was incorporated in 1979 and is headquartered in Marlborough, Massachusetts.","industry":"Medical Devices","sector":"Healthcare","marketCap":85673508864,"trailingPE":24.117153,"forwardPE":15.316263,"pegRatio":0.7,"priceToBook":3.3122628,"priceToSales":4.1560836,"profitMargin":17.294,"operatingMargin":20.603001000000003,"grossMargin":68.943,"returnOnEquity":14.661,"returnOnAssets":6.0749996,"revenueGrowthYoy":11.600000000000001,"earningsGrowthYoy":100,"earningsQuarterlyGrowthYoy":99,"debtToEquity":42.25,"currentRatio":1.9,"quickRatio":0.98,"freeCashFlow":2807124992,"operatingCashFlow":4341000192,"totalCash":1452999936,"totalDebt":11029000192,"revenue":20614000640,"dividendYield":null,"payoutRatio":0,"beta":0.623,"fiftyTwoWeekHigh":109.5,"fiftyTwoWeekLow":52.52,"targetMeanPrice":83.46875,"targetHighPrice":106,"targetLowPrice":60,"recommendationKey":"strong_buy","numberOfAnalystOpinions":32,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":0.8,"epsEstimate":0.78722,"surprisePct":1.6199999999999999},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":0.75,"epsEstimate":0.72522,"surprisePct":3.42},{"date":"2025-09-30","period":"-3q","epsActual":0.75,"epsEstimate":0.71366,"surprisePct":5.09},{"date":"2025-12-31","period":"-2q","epsActual":0.8,"epsEstimate":0.78105,"surprisePct":2.4300002000000003},{"date":"2026-03-31","period":"-1q","epsActual":0.8,"epsEstimate":0.78722,"surprisePct":1.6199999999999999}],"revenueHistory":[{"date":"2025-03-31","value":4663000000},{"date":"2025-06-