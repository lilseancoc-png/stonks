tilize its CRM platform; and customer success; phone and/or email and chat-based support services; and helps customers by providing Customer Success Manager and Partner Development Manager digital channels through educational content academey. It serves mid-market business-to-business companies. The company was incorporated in 2005 and is headquartered in Cambridge, Massachusetts.","industry":"Software - Application","sector":"Technology","marketCap":10944573440,"trailingPE":111.93718,"forwardPE":13.6930065,"pegRatio":0.32,"priceToBook":5.5627832,"priceToSales":3.3184237,"profitMargin":3.04,"operatingMargin":3.2960000000000003,"grossMargin":83.655,"returnOnEquity":5.011,"returnOnAssets":1.0980001,"revenueGrowthYoy":23.400000000000002,"earningsGrowthYoy":null,"earningsQuarterlyGrowthYoy":null,"debtToEquity":12.384,"currentRatio":1.609,"quickRatio":1.348,"freeCashFlow":656183360,"operatingCashFlow":797971968,"totalCash":1691052032,"totalDebt":247291008,"revenue":3298124032,"dividendYield":null,"payoutRatio":0,"beta":1.229,"fiftyTwoWeekHigh":611,"fiftyTwoWeekLow":173.25,"targetMeanPrice":280.16333,"targetHighPrice":450,"targetLowPrice":180,"recommendationKey":"buy","numberOfAnalystOpinions":33,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":2.72,"epsEstimate":2.46745,"surprisePct":10.24},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":2.19,"epsEstimate":2.12399,"surprisePct":3.11},{"date":"2025-09-30","period":"-3q","epsActual":2.66,"epsEstimate":2.58596,"surprisePct":2.86},{"date":"2025-12-31","period":"-2q","epsActual":3.09,"epsEstimate":2.98805,"surprisePct":3.4099999999999997},{"date":"2026-03-31","period":"-1q","epsActual":2.72,"epsEstimate":2.46745,"surprisePct":10.24}],"revenueHistory":[{"date":"2025-03-31","value":714137000},{"date":"2025-06-30","value":760866000},{"date":"2025-09-30","value":809518000},{"date":"2025-12-31","value":846746000},{"date":"2026-03-31","value":880995000}],"grossProfitHistory":[{"date":"2025-03-31","va