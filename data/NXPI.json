 products; radio frequency devices, and security controllers, as well as semiconductor-based environmental and inertial sensors, including pressure, inertial, magnetic, and gyroscopic sensors. Its products are used in various applications, including automotive, industrial and Internet of Things, mobile, and communication infrastructure. The company markets its products to direct sales offices and independent distributors. NXP Semiconductors N.V. was incorporated in 2006 and is headquartered in Eindhoven, the Netherlands.","industry":"Semiconductors","sector":"Technology","marketCap":82842066944,"trailingPE":31.309639,"forwardPE":18.613094,"pegRatio":0.81,"priceToBook":7.5860033,"priceToSales":6.5669494,"profitMargin":21.031,"operatingMargin":47.375,"grossMargin":55.632000000000005,"returnOnEquity":25.812997999999997,"returnOnAssets":9.6429996,"revenueGrowthYoy":12.2,"earningsGrowthYoy":130.7,"earningsQuarterlyGrowthYoy":129,"debtToEquity":103.991,"currentRatio":2.241,"quickRatio":1.364,"freeCashFlow":3119000064,"operatingCashFlow":3048000000,"totalCash":3708000000,"totalDebt":11724000256,"revenue":12615000064,"dividendYield":1.28,"payoutRatio":38.779998,"beta":1.776,"fiftyTwoWeekHigh":329.12,"fiftyTwoWeekLow":183,"targetMeanPrice":302.3871,"targetHighPrice":380,"targetLowPrice":200,"recommendationKey":"buy","numberOfAnalystOpinions":31,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":3.05,"epsEstimate":2.98433,"surprisePct":2.1999999999999997},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":2.72,"epsEstimate":2.65861,"surprisePct":2.31},{"date":"2025-09-30","period":"-3q","epsActual":3.11,"epsEstimate":3.11837,"surprisePct":-0.27},{"date":"2025-12-31","period":"-2q","epsActual":3.35,"epsEstimate":3.31109,"surprisePct":1.17999995},{"date":"2026-03-31","period":"-1q","epsActual":3.05,"epsEstimate":2.98433,"surprisePct":2.1999999999999997}],"revenueHistory":[{"date":"2025-03-31","value":2835000000},{"date":"2025-06-30","value":2926000000