. Further, it provides combat-proven autonomous systems, optical sensors, advanced optics, resilient energy solutions, and radio frequency payloads, as well as provides intelligence, surveillance, and reconnaissance capabilities for customers including the U.S. Department of War, U.S. Federal Civilian Agencies and allied governments across multiple domains. Redwire Corporation was founded in 2010 and is headquartered in Jacksonville, Florida.","industry":"Aerospace & Defense","sector":"Industrials","marketCap":4380190208,"trailingPE":null,"forwardPE":-53.707317,"pegRatio":null,"priceToBook":4.0065503,"priceToSales":11.807778,"profitMargin":-80.9,"operatingMargin":-71.836,"grossMargin":12.858,"returnOnEquity":-48.748999999999995,"returnOnAssets":-15.015999999999998,"revenueGrowthYoy":57.9,"earningsGrowthYoy":null,"earningsQuarterlyGrowthYoy":null,"debtToEquity":11.325,"currentRatio":1.752,"quickRatio":1.258,"freeCashFlow":-71324128,"operatingCashFlow":-138916000,"totalCash":144506000,"totalDebt":131888000,"revenue":370958016,"dividendYield":null,"payoutRatio":0,"beta":2.422,"fiftyTwoWeekHigh":23.1,"fiftyTwoWeekLow":4.87,"targetMeanPrice":14.33333,"targetHighPrice":22,"targetLowPrice":7,"recommendationKey":"strong_buy","numberOfAnalystOpinions":9,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":-0.1216,"epsEstimate":-0.17,"surprisePct":28.470000000000002},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":-1.41,"epsEstimate":-0.15,"surprisePct":-840},{"date":"2025-09-30","period":"-3q","epsActual":-0.191,"epsEstimate":-0.13,"surprisePct":-46.92},{"date":"2025-12-31","period":"-2q","epsActual":-0.2201,"epsEstimate":-0.16,"surprisePct":-37.56},{"date":"2026-03-31","period":"-1q","epsActual":-0.1216,"epsEstimate":-0.17,"surprisePct":28.470000000000002}],"revenueHistory":[{"date":"2025-03-31","value":61395000},{"date":"2025-06-30","value":61760000},{"date":"2025-09-30","value":103432000},{"date":"2025-12-31","value":108794000},{"date":"2026-03