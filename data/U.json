sumption services; professional services, including consulting, platform integration, training, and custom application and workflow development services; and advertising and game publishing services. It provides its solutions directly through its online store, field sales operations, independent distributors, and resellers. The company serves enterprises, mid-market companies, government, and non-profit institutions; mid-sized, small, and independent businesses; and individuals from various industries. Unity Software Inc. was founded in 2004 and is headquartered in San Francisco, California.","industry":"Software - Application","sector":"Technology","marketCap":14028051456,"trailingPE":null,"forwardPE":24.078735,"pegRatio":null,"priceToBook":4.296697,"priceToSales":7.295311,"profitMargin":-34.986,"operatingMargin":-15.232000000000001,"grossMargin":74.693,"returnOnEquity":-20.111999,"returnOnAssets":-3.995,"revenueGrowthYoy":16.8,"earningsGrowthYoy":null,"earningsQuarterlyGrowthYoy":null,"debtToEquity":71.565,"currentRatio":1.947,"quickRatio":1.862,"freeCashFlow":600423232,"operatingCashFlow":481215008,"totalCash":2140861056,"totalDebt":2319513088,"revenue":1922886016,"dividendYield":null,"payoutRatio":0,"beta":2.038,"fiftyTwoWeekHigh":52.15,"fiftyTwoWeekLow":16.78,"targetMeanPrice":34.84375,"targetHighPrice":43,"targetLowPrice":28,"recommendationKey":"buy","numberOfAnalystOpinions":23,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":0.23,"epsEstimate":0.24018,"surprisePct":-4.24},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":0.18,"epsEstimate":0.14757,"surprisePct":21.98},{"date":"2025-09-30","period":"-3q","epsActual":0.2,"epsEstimate":0.16729,"surprisePct":19.549999},{"date":"2025-12-31","period":"-2q","epsActual":0.24,"epsEstimate":0.20898,"surprisePct":14.840000999999999},{"date":"2026-03-31","period":"-1q","epsActual":0.23,"epsEstimate":0.24018,"surprisePct":-4.24}],"revenueHistory":[{"date":"2025-03-31","value":435000000},{"da