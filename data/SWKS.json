itches, synthesizers, timing devices, voltage-controlled oscillators/synthesizers, and voltage regulators. The company sells its products through direct sales force, electronic component distributors, and independent sales representatives. Its products are used in aerospace, automotive, broadband, cellular infrastructure, connected home, defense, entertainment and gaming, industrial, medical, smartphone, tablet, and wearables applications. The company was founded in 1962 and is headquartered in Irvine, California.","industry":"Semiconductors","sector":"Technology","marketCap":11354145792,"trailingPE":31.454165,"forwardPE":14.669675,"pegRatio":1.78,"priceToBook":1.9691674,"priceToSales":2.807444,"profitMargin":8.931000000000001,"operatingMargin":7.704,"grossMargin":41.075,"returnOnEquity":6.171,"returnOnAssets":3.537,"revenueGrowthYoy":-1,"earningsGrowthYoy":-44.9,"earningsQuarterlyGrowthYoy":-48.199999999999996,"debtToEquity":20.632,"currentRatio":2.376,"quickRatio":1.336,"freeCashFlow":687837504,"operatingCashFlow":960000000,"totalCash":1421799936,"totalDebt":1189600000,"revenue":4044300032,"dividendYield":3.7600000000000002,"payoutRatio":117.91999,"beta":1.476,"fiftyTwoWeekHigh":90.9,"fiftyTwoWeekLow":51.93,"targetMeanPrice":74.15789,"targetHighPrice":106,"targetLowPrice":55,"recommendationKey":"hold","numberOfAnalystOpinions":19,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":1.15,"epsEstimate":1.04446,"surprisePct":10.100000000000001},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":1.33,"epsEstimate":1.2429,"surprisePct":7.01},{"date":"2025-09-30","period":"-3q","epsActual":1.76,"epsEstimate":1.53277,"surprisePct":14.819999000000001},{"date":"2025-12-31","period":"-2q","epsActual":1.54,"epsEstimate":1.39895,"surprisePct":10.08},{"date":"2026-03-31","period":"-1q","epsActual":1.15,"epsEstimate":1.04446,"surprisePct":10.100000000000001}],"revenueHistory":[{"date":"2025-03-31","value":953200000},{"date":"2025-06-30","value":96500000