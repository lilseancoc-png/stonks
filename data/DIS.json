, Shanghai Disney Resort, Disney Cruise Line, Disney Vacation Club, National Geographic Expeditions, and Adventures by Disney, as well as Aulani, a Disney resort and spa in Hawaii. Further, it licenses its intellectual property (IP) to a third party that owns and operates Tokyo Disney Resort; licenses trade names, characters, visual, literary, and other IP for use on merchandise, published materials, and games; operates a direct-to-home satellite distribution platform; sells branded merchandise through retail, online, and wholesale businesses; and develops and publishes books, comic books, and magazines. The company was founded in 1923 and is based in Burbank, California.","industry":"Entertainment","sector":"Communication Services","marketCap":174050557952,"trailingPE":16.0368,"forwardPE":13.373808,"pegRatio":2.58,"priceToBook":1.6089058,"priceToSales":1.7894837,"profitMargin":11.540000000000001,"operatingMargin":15.512,"grossMargin":37.16,"returnOnEquity":11.01,"returnOnAssets":4.449,"revenueGrowthYoy":6.5,"earningsGrowthYoy":-29.799999999999997,"earningsQuarterlyGrowthYoy":-31.4,"debtToEquity":41.069,"currentRatio":0.679,"quickRatio":0.554,"freeCashFlow":3751375104,"operatingCashFlow":15792000000,"totalCash":5681999872,"totalDebt":47358001152,"revenue":97263001600,"dividendYield":1.46,"payoutRatio":20,"beta":1.416,"fiftyTwoWeekHigh":124.69,"fiftyTwoWeekLow":92.19,"targetMeanPrice":129.4931,"targetHighPrice":164,"targetLowPrice":77,"recommendationKey":"strong_buy","numberOfAnalystOpinions":29,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":1.57,"epsEstimate":1.49547,"surprisePct":4.9799999999999995},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":1.61,"epsEstimate":1.44649,"surprisePct":11.3000005},{"date":"2025-09-30","period":"-3q","epsActual":1.11,"epsEstimate":1.02382,"surprisePct":8.42},{"date":"2025-12-31","period":"-2q","epsActual":1.63,"epsEstimate":1.5758,"surprisePct":3.44},{"date":"2026-03-31","period":"-1q","epsActual":