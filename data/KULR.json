e used in space, aerospace, defence, telecom, and other critical infrastructure. KULR Technology Group, Inc. has a strategic collaboration with Robinson Helicopter Company, Inc. to develop battery system for an eR66 battery-electric helicopter demonstrator. The company was formerly known as KT High-Tech Marketing, Inc. and changed its name to KULR Technology Group, Inc. in August 2018. The company was founded in 2013 and is headquartered in Webster, Texas.","industry":"Electronic Components","sector":"Technology","marketCap":221109248,"trailingPE":null,"forwardPE":null,"pegRatio":null,"priceToBook":2.3374083,"priceToSales":11.907935,"profitMargin":0,"operatingMargin":-152.38401,"grossMargin":-0.784,"returnOnEquity":-77.298,"returnOnAssets":-25.074,"revenueGrowthYoy":97.89999999999999,"earningsGrowthYoy":null,"earningsQuarterlyGrowthYoy":null,"debtToEquity":6.722,"currentRatio":1.688,"quickRatio":1.305,"freeCashFlow":-23502010,"operatingCashFlow":-43962404,"totalCash":7676308,"totalDebt":6357675,"revenue":18568228,"dividendYield":null,"payoutRatio":0,"beta":2.003,"fiftyTwoWeekHigh":10.56,"fiftyTwoWeekLow":1.94,"targetMeanPrice":8,"targetHighPrice":8,"targetLowPrice":8,"recommendationKey":"strong_buy","numberOfAnalystOpinions":1,"lastQuarter":{"date":"2025-09-30","period":"-2q","epsActual":-0.179,"epsEstimate":-0.08,"surprisePct":-123.75},"earningsHistory":[{"date":"2025-03-31","period":"-4q","epsActual":-0.4928,"epsEstimate":-0.08,"surprisePct":-516},{"date":"2025-06-30","period":"-3q","epsActual":0.2588,"epsEstimate":-0.08,"surprisePct":423.50000000000006},{"date":"2025-09-30","period":"-2q","epsActual":-0.179,"epsEstimate":-0.08,"surprisePct":-123.75}],"revenueHistory":[{"date":"2025-03-31","value":2448606},{"date":"2025-06-30","value":3972997},{"date":"2025-09-30","value":6884840},{"date":"2025-12-31","value":2863961},{"date":"2026-03-31","value":4846430}],"grossProfitHistory":[{"date":"2025-03-31","value":206345},{"date":"2025-06-30","value":713710},{"date":"2025