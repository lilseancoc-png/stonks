ototype, and publish; Payload CMS is an open-source, headless content management system and application framework acquired by Figma; Figma Make, an AI tool to design and prompt way to a functional prototype; Figma Weave for AI-powered media generation and editing. The company was incorporated in 2012 and is headquartered in San Francisco, California.","industry":"Software - Application","sector":"Technology","marketCap":12004715520,"trailingPE":null,"forwardPE":67.37441,"pegRatio":4.11,"priceToBook":8.205128,"priceToSales":10.33973,"profitMargin":-123.834,"operatingMargin":-41.206002000000005,"grossMargin":79.782,"returnOnEquity":-101.704,"returnOnAssets":-43.620998,"revenueGrowthYoy":46.1,"earningsGrowthYoy":null,"earningsQuarterlyGrowthYoy":null,"debtToEquity":3.855,"currentRatio":2.5,"quickRatio":2.359,"freeCashFlow":813476480,"operatingCashFlow":250812000,"totalCash":1638464000,"totalDebt":56164000,"revenue":1161027968,"dividendYield":null,"payoutRatio":0,"beta":null,"fiftyTwoWeekHigh":142.92,"fiftyTwoWeekLow":16.6,"targetMeanPrice":36.875,"targetHighPrice":60,"targetLowPrice":25,"recommendationKey":"hold","numberOfAnalystOpinions":8,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":0.1,"epsEstimate":0.06212,"surprisePct":60.980000000000004},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":0.0854,"epsEstimate":0.07691,"surprisePct":11.04},{"date":"2025-09-30","period":"-3q","epsActual":0.132,"epsEstimate":0.04676,"surprisePct":182.28999},{"date":"2025-12-31","period":"-2q","epsActual":0.08,"epsEstimate":0.06469,"surprisePct":23.669999999999998},{"date":"2026-03-31","period":"-1q","epsActual":0.1,"epsEstimate":0.06212,"surprisePct":60.980000000000004}],"revenueHistory":[{"date":"2025-03-31","value":228199000},{"date":"2025-06-30","value":249640000},{"date":"2025-09-30","value":274173000},{"date":"2025-12-31","value":303776000},{"date":"2026-03-31","value":333439000}],"grossProfitHistory":[{"date":"2025-03-31","value":208747000},{"dat