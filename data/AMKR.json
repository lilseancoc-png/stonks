e":67.94,"bars":251,"rsi":48.68,"rsi5d":46.2,"macd":{"line":0.9163,"signal":1.712,"hist":-0.7957},"sr":{"s20":62.45,"r20":78.96,"s50":40.69,"r50":79.23,"s100":40.22,"r100":79.23,"s200":22.74,"r200":79.23},"sma":{"sma20":71.32,"sma50":63.62,"sma100":55.93,"sma200":44.32},"volRegime":{"rv30":0.6647,"rv30Pctile":47,"samples":221},"volume":{"today":524942,"avg20":5089075,"rvol":0.1,"priceMove1dPct":-2.33,"conviction":"weak"},"chartPattern":{"pattern":"None","type":null,"direction":null,"confidence":null,"explanation":"The price action shows significant volatility and several upward and downward swings, but no clear formation of a classic chart pattern like a cup and handle, head and shoulders, or triangle is evident. The recent price action does not exhibit the distinct rounded bottom and handle, or the three-peak structure with a neckline, or the specific converging trendlines required for these patterns.","signal":"","builtAt":"2026-06-01T14:03:14.636Z"}},"fundamentals":{"name":"Amkor Technology, Inc.","longBusinessSummary":"Amkor Technology, Inc. provides outsourced semiconductor packaging and test services in the United States, Japan, Europe, and the Asia Pacific. It offers turnkey packaging and test services, including semiconductor wafer bump, wafer probe, wafer back-grind, package design, packaging, burn-in, system-level and final test, and drop shipment services; flip chip scale package products for smartphones, tablets, and other mobile consumer electronic devices; flip chip stacked chip scale packages that are used to stack memory digital baseband, and as applications processors in mobile devices; flip-chip ball grid array packages for various networking, storage, computing, automotive, and consumer applications; and memory products for system memory or platform data storage. The company provides wafer-level CSP packages for power management, transceivers, sensors, wireless charging, codecs, and specialty silicon; wafer-level fan-out packages used in power management, transceivers, radar, and specialty silicon; silicon wafer integrated fan-out technology that replaces a laminate substrate with a thinner structure; leadframe packages for electronic devices and mixed-signal applications; and substrate-based wirebond packages used to connect a die to a substrate. In addition, it offers micro-electro-mechanical systems packages that are miniaturized mechanical and electromechanical devices; and advanced system-in-package modules used in radio frequency and front end modules, basebands, connectivity, fingerprint sensors, display and touch screen drivers, sensors and MEMS, and NAND memory and solid-state drives. Further, the company provides wafer, package, and system level test services, as well as burn-in test and test development services. It serves integrated device manufacturers, fabless semiconductor companies, original equipment manufacturers, and contract foundries. Amkor Technology, Inc. was founded in 1968 and is headquartered in Tempe, Arizona.","industry":"Semiconductor Equipment & Materials","sector":"Technology","marketCap":16840459264,"trailingPE":39.04598,"forwardPE":27.708559,"pegRatio":0.76,"priceToBook":3.7139893,"priceToSales":2.3815873,"profitMargin":6.1680003999999995,"operatingMargin":5.955,"grossMargin":14.425999000000001,"returnOnEquity":10.005999000000001,"returnOnAssets":4.403,"revenueGrowthYoy":27.500000000000004,"earningsGrowthYoy":285.59999999999997,"earningsQuarterlyGrowthYoy":294.5,"debtToEquity":35.4,"currentRatio":2.01,"quickRatio":1.698,"freeCashFlow":-47146500,"operatingCashFlow":1216544000,"totalCash":1848499968,"totalDebt":1617483008,"revenue":7071107072,"dividendYield":0.47999998000000005,"payoutRatio":19.1,"beta":2.306,"fiftyTwoWeekHigh":79.23,"fiftyTwoWeekLow":17.81,"targetMeanPrice":75.5,"targetHighPrice":90,"targetLowPrice":60,"recommendationKey":"buy","numberOfAnalystOpinions":8,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":0.33,"epsEstimate":0.24337,"surprisePct":35.