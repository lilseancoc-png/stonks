"oi":115,"v":60},{"s":75,"b":26,"a":30.5,"l":27.25,"iv":0.7365748999023438,"oi":6,"v":1},{"s":80,"b":29,"a":34,"l":30,"iv":0.7282131671142578,"oi":15,"v":2},{"s":85,"b":32.5,"a":37.5,"l":32.2,"iv":0.7240628179931641,"oi":3,"v":1},{"s":90,"b":37,"a":40.2,"l":35.9,"iv":0.7200345379638673,"oi":1,"v":null},{"s":100,"b":43.5,"a":48.5,"l":43.54,"iv":0.7103300451660157,"oi":12,"v":null}]}},"technicals":{"asOfClose":72.19,"bars":151,"rsi":55.63,"macd":{"line":1.3967,"signal":2.286,"hist":-0.8893},"sr":{"s20":62.45,"r20":78.96,"s50":40.69,"r50":79.23},"volRegime":{"rv30":0.7025,"rv30Pctile":40,"samples":121},"volume":{"today":5455481,"avg20":5447170,"rvol":1,"priceMove1dPct":-1.73,"conviction":"mixed"}},"fundamentals":{"name":"Amkor Technology, Inc.","longBusinessSummary":"Amkor Technology, Inc. provides outsourced semiconductor packaging and test services in the United States, Japan, Europe, and the Asia Pacific. It offers turnkey packaging and test services, including semiconductor wafer bump, wafer probe, wafer back-grind, package design, packaging, burn-in, system-level and final test, and drop shipment services; flip chip scale package products for smartphones, tablets, and other mobile consumer electronic devices; flip chip stacked chip scale packages that are used to stack memory digital baseband, and as applications processors in mobile devices; flip-chip ball grid array packages for various networking, storage, computing, automotive, and consumer applications; and memory products for system memory or platform data storage. The company provides wafer-level CSP packages for power management, transceivers, sensors, wireless charging, codecs, and specialty silicon; wafer-level fan-out packages used in power management, transceivers, radar, and specialty silicon; silicon wafer integrated fan-out technology that replaces a laminate substrate with a thinner structure; leadframe packages for electronic devices and mixed-signal applications; and substrate-based wirebond packages used to connect a die to a substrate. In addition, it offers micro-electro-mechanical systems packages that are miniaturized mechanical and electromechanical devices; and advanced system-in-package modules used in radio frequency and front end modules, basebands, connectivity, fingerprint sensors, display and touch screen drivers, sensors and MEMS, and NAND memory and solid-state drives. Further, the company provides wafer, package, and system level test services, as well as burn-in test and test development services. It serves integrated device manufacturers, fabless semiconductor companies, original equipment manufacturers, and contract foundries. Amkor Technology, Inc. was founded in 1968 and is headquartered in Tempe, Arizona.","industry":"Semiconductor Equipment & Materials","sector":"Technology","marketCap":17893916672,"trailingPE":41.488506,"forwardPE":29.441874,"pegRatio":0.76,"priceToBook":3.9463186,"priceToSales":2.530568,"profitMargin":6.1680003999999995,"operatingMargin":5.955,"grossMargin":14.425999000000001,"returnOnEquity":10.005999000000001,"returnOnAssets":4.403,"revenueGrowthYoy":27.500000000000004,"earningsGrowthYoy":285.59999999999997,"earningsQuarterlyGrowthYoy":294.5,"debtToEquity":35.4,"currentRatio":2.01,"quickRatio":1.698,"freeCashFlow":-47146500,"operatingCashFlow":1216544000,"totalCash":1848499968,"totalDebt":1617483008,"revenue":7071107072,"dividendYield":0.44999999999999996,"payoutRatio":19.1,"beta":2.306,"fiftyTwoWeekHigh":79.23,"fiftyTwoWeekLow":17.79,"targetMeanPrice":75.5,"targetHighPrice":90,"targetLowPrice":60,"recommendationKey":"buy","numberOfAnalystOpinions":8,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":0.33,"epsEstimate":0.24337,"surprisePct":35.599998},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":0.22,"epsEstimate":0.15757,"surprisePct":39.62},{"date":"2025-09-30","period":"-3q","epsActual":0.51,"epsEstimate":0.42629,"surprisePct":19.639999},{"date":"2025-12-31","period":"-2q","epsA