,"b":26,"a":30.5,"l":27.25,"iv":0.7365748999023438,"oi":6,"v":1},{"s":80,"b":29,"a":34,"l":30,"iv":0.7282131671142578,"oi":15,"v":2},{"s":85,"b":32.5,"a":37.5,"l":32.2,"iv":0.7240628179931641,"oi":3,"v":1},{"s":90,"b":37,"a":40.2,"l":35.9,"iv":0.7200345379638673,"oi":1,"v":null},{"s":100,"b":43.5,"a":48.5,"l":43.54,"iv":0.7103300451660157,"oi":12,"v":null}]}},"technicals":{"asOfClose":72.19,"bars":151,"rsi":55.63,"macd":{"line":1.3967,"signal":2.286,"hist":-0.8893},"sr":{"s20":62.45,"r20":78.96,"s50":40.69,"r50":79.23},"volRegime":{"rv30":0.7025,"rv30Pctile":40,"samples":121},"volume":{"today":5403150,"avg20":5447170,"rvol":0.99,"priceMove1dPct":-1.73,"conviction":"mixed"}},"fundamentals":{"name":"Amkor Technology, Inc.","longBusinessSummary":"Amkor Technology, Inc. provides outsourced semiconductor packaging and test services in the United States, Japan, Europe, and the Asia Pacific. It offers turnkey packaging and test services, including semiconductor wafer bump, wafer probe, wafer back-grind, package design, packaging, burn-in, system-level and final test, and drop shipment services; flip chip scale package products for smartphones, tablets, and other mobile consumer electronic devices; flip chip stacked chip scale packages that are used to stack memory digital baseband, and as applications processors in mobile devices; flip-chip ball grid array packages for various networking, storage, computing, automotive, and consumer applications; and memory products for system memory or platform data storage. The company provides wafer-level CSP packages for power management, transceivers, sensors, wireless charging, codecs, and specialty silicon; wafer-level fan-out packages used in power management, transceivers, radar, and specialty silicon; silicon wafer integrated fan-out technology that replaces a laminate substrate with a thinner structure; leadframe packages for electronic devices and mixed-signal applications; and substrate-based wirebond packages used to connect 