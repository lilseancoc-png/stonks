lutions and mission support services; mobile communication, computers, and command-and-control mission systems; intelligence, surveillance, and reconnaissance solutions to military, intelligence, and federal civilian customers; cloud services, cybersecurity, network modernization, artificial intelligence; machine learning; application development, high-performance computing, and 5G and advanced communications services; and unmanned undersea vehicle manufacturing and assembly services. The company was founded in 1899 and is headquartered in Reston, Virginia.","industry":"Aerospace & Defense","sector":"Industrials","marketCap":93896056832,"trailingPE":21.864609,"forwardPE":19.134329,"pegRatio":2.59,"priceToBook":3.5950134,"priceToSales":1.7450204,"profitMargin":8.068,"operatingMargin":10.541,"grossMargin":15.241,"returnOnEquity":17.974001,"returnOnAssets":6.005,"revenueGrowthYoy":10.299999999999999,"earningsGrowthYoy":12,"earningsQuarterlyGrowthYoy":13.200000000000001,"debtToEquity":37.701,"currentRatio":1.384,"quickRatio":0.795,"freeCashFlow":5289500160,"operatingCashFlow":7411999744,"totalCash":3654000128,"totalDebt":9831999488,"revenue":53808001024,"dividendYield":1.7500000000000002,"payoutRatio":38.33,"beta":0.345,"fiftyTwoWeekHigh":369.7,"fiftyTwoWeekLow":268.1,"targetMeanPrice":392.21524,"targetHighPrice":444,"targetLowPrice":313,"recommendationKey":"buy","numberOfAnalystOpinions":21,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":4.1,"epsEstimate":3.69302,"surprisePct":11.020000000000001},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":3.74,"epsEstimate":3.54185,"surprisePct":5.59},{"date":"2025-09-30","period":"-3q","epsActual":3.88,"epsEstimate":3.71045,"surprisePct":4.5700002},{"date":"2025-12-31","period":"-2q","epsActual":4.17,"epsEstimate":4.10665,"surprisePct":1.54},{"date":"2026-03-31","period":"-1q","epsActual":4.1,"epsEstimate":3.69302,"surprisePct":11.020000000000001}],"revenueHistory":[{"date":"2025-03-31","value":12