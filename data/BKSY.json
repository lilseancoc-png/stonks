ther, it develops and delivers customized advanced satellites and payload systems. The company's products and services are used in national security, supply chain resilience, economic intelligence, and other critical decision-making requirements. It serves the United States federal government and its agencies; international governments, agencies, and organizations; and the commercial and industrial infrastructure markets, including energy and utilities, insurance, commodities, mining, manufacturing, logistics, supply chain management, agriculture, environmental monitoring, disaster and risk management, engineering and construction, retail, and consumer behavior. BlackSky Technology Inc. was founded in 2014 and is headquartered in Herndon, Virginia.","industry":"Specialty Business Services","sector":"Industrials","marketCap":1910109056,"trailingPE":null,"forwardPE":-94.44569,"pegRatio":null,"priceToBook":23.418062,"priceToSales":19.52977,"profitMargin":-89.065003,"operatingMargin":-89.232004,"grossMargin":69.291,"returnOnEquity":-102.69101,"returnOnAssets":-10.597999399999999,"revenueGrowthYoy":-29.7,"earningsGrowthYoy":null,"earningsQuarterlyGrowthYoy":null,"debtToEquity":261.005,"currentRatio":3.458,"quickRatio":3.066,"freeCashFlow":-56810752,"operatingCashFlow":-57912000,"totalCash":115521000,"totalDebt":210904992,"revenue":97805000,"dividendYield":null,"payoutRatio":0,"beta":2.439,"fiftyTwoWeekHigh":52.05,"fiftyTwoWeekLow":10.61,"targetMeanPrice":40.5,"targetHighPrice":50,"targetLowPrice":34,"recommendationKey":"strong_buy","numberOfAnalystOpinions":7,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":-0.4772,"epsEstimate":-0.395,"surprisePct":-20.809999},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":-0.397,"epsEstimate":-0.4825,"surprisePct":17.719999},{"date":"2025-09-30","period":"-3q","epsActual":-0.4291,"epsEstimate":-0.355,"surprisePct":-20.87},{"date":"2025-12-31","period":"-2q","epsActual":-0.0578,"epsEstimate":-0.2775,"sur