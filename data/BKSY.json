mmodities, mining, manufacturing, logistics, supply chain management, agriculture, environmental monitoring, disaster and risk management, engineering and construction, retail, and consumer behavior. BlackSky Technology Inc. was founded in 2014 and is headquartered in Herndon, Virginia.","industry":"Specialty Business Services","sector":"Industrials","marketCap":1798674432,"trailingPE":null,"forwardPE":-88.935776,"pegRatio":null,"priceToBook":22.051867,"priceToSales":18.390413,"profitMargin":-89.065003,"operatingMargin":-89.232004,"grossMargin":69.291,"returnOnEquity":-102.69101,"returnOnAssets":-10.597999399999999,"revenueGrowthYoy":-29.7,"earningsGrowthYoy":null,"earningsQuarterlyGrowthYoy":null,"debtToEquity":261.005,"currentRatio":3.458,"quickRatio":3.066,"freeCashFlow":-56810752,"operatingCashFlow":-57912000,"totalCash":115521000,"totalDebt":210904992,"revenue":97805000,"dividendYield":null,"payoutRatio":0,"beta":2.439,"fiftyTwoWeekHigh":52.88,"fiftyTwoWeekLow":10.61,"targetMeanPrice":40.5,"targetHighPrice":50,"targetLowPrice":34,"recommendationKey":"none","numberOfAnalystOpinions":7,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":-0.4772,"epsEstimate":-0.395,"surprisePct":-20.809999},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":-0.397,"epsEstimate":-0.4825,"surprisePct":17.719999},{"date":"2025-09-30","period":"-3q","epsActual":-0.4291,"epsEstimate":-0.355,"surprisePct":-20.87},{"date":"2025-12-31","period":"-2q","epsActual":-0.0578,"epsEstimate":-0.2775,"surprisePct":79.17},{"date":"2026-03-31","period":"-1q","epsActual":-0.4772,"epsEstimate":-0.395,"surprisePct":-20.809999}],"revenueHistory":[{"date":"2025-03-31","value":29544000},{"date":"2025-06-30","value":22199000},{"date":"2025-09-30","value":19618000},{"date":"2025-12-31","value":35214000},{"date":"2026-03-31","value":20774000}],"grossProfitHistory":[{"date":"2025-03-31","value":16944000},{"date":"2025-06-30","value":15952000},{"date":"2025-09-30","value":12803000},{