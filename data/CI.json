,{"s":400,"b":121.5,"a":126,"l":118.8,"iv":0.24279016494750977,"oi":2,"v":2}]}},"technicals":{"asOfClose":280.62,"bars":150,"rsi":47.07,"macd":{"line":1.6812,"signal":3.0375,"hist":-1.3563},"sr":{"s20":274.01,"r20":303.33,"s50":257.85,"r50":303.33},"volRegime":{"rv30":0.2859,"rv30Pctile":71,"samples":120},"volume":{"today":607413,"avg20":1725855,"rvol":0.35,"priceMove1dPct":-1.96,"conviction":"weak"}},"fundamentals":{"name":"The Cigna Group","longBusinessSummary":"The Cigna Group, together with its subsidiaries, provides insurance and related products and services in the United States. It operates through two segments: Evernorth Health Services and Cigna Healthcare. The Evernorth Health Services segment includes Pharmacy Benefit Services and Specialty and Care Services, offering pharmacy benefit management, drug claim adjudication, retail pharmacy network administration, benefit design consultation, drug utilization review, drug formulary management, pharmacy benefits, home delivery pharmacy, specialty pharmacy, specialty pharmaceutical distribution, and clinical programs for whole-person health outcomes. The Cigna Healthcare segment comprises U.S. Healthcare and International Health, delivering comprehensive medical and coordinated solutions such as employer medical plans, individual and family plans, behavioral health, consumer health engagement, dental, pharmacy management, stop-loss insurance, global health care, and local health care solutions, as well as health care benefits for mobile individuals and employees of multinational organizations. The company offers other operations, including corporate-owned life insurance, reinsurance, and certain run-off and non-strategic businesses. The company distributes its products and services through brokers and consultants; directly to employers, unions and other groups, or individuals; and private and public exchanges. The company was formerly known as Cigna Corporation and changed its name to The Cigna Group in February 2023. The company was founded in 1792 and is headquartered in Bloomfield, Connecticut.","industry":"Healthcare Plans","sector":"Healthcare","marketCap":74233077760,"trailingPE":2.4676397,"forwardPE":8.379125,"pegRatio":0.86,"priceToBook":1.7591083,"priceToSales":0.26712924,"profitMargin":2.263,"operatingMargin":5.4780003,"grossMargin":9.149000000000001,"returnOnEquity":16.268998,"returnOnAssets":4.782,"revenueGrowthYoy":4.6,"earningsGrowthYoy":29.099999999999998,"earningsQuarterlyGrowthYoy":25,"debtToEquity":72.805,"currentRatio":0.818,"quickRatio":0.657,"freeCashFlow":6923375104,"operatingCashFlow":8812000256,"totalCash":7852000256,"totalDebt":30900000768,"revenue":277892005888,"dividendYield":2.18,"payoutRatio":5.3600002,"beta":0.313,"fiftyTwoWeekHigh":338.89,"fiftyTwoWeekLow":239.51,"targetMeanPrice":341.75,"targetHighPrice":400,"targetLowPrice":290,"recommendationKey":"strong_buy","numberOfAnalystOpinions":24,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":7.79,"epsEstimate":7.60633,"surprisePct":2.41},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":7.2,"epsEstimate":7.15372,"surprisePct":0.64999997},{"date":"2025-09-30","period":"-3q","epsActual":7.83,"epsEstimate":7.64116,"surprisePct":2.4699999999999998},{"date":"2025-12-31","period":"-2q","epsActual":8.08,"epsEstimate":7.88281,"surprisePct":2.5},{"date":"2026-03-31","period":"-1q","epsActual":7.79,"epsEstimate":7.60633,"surprisePct":2.41}],"revenueHistory":[{"date":"2025-03-31","value":65500000000},{"date":"2025-06-30","value":66942000000},{"date":"2025-09-30","value":69515000000},{"date":"2025-12-31","value":72372000000},{"date":"2026-03-31","value":273168000000}],"grossProfitHistory":[{"date":"2025-03-31","value":6368000000},{"date":"2025-06-30","value":5925000000},{"date":"2025-09-30","value":6143000000},{"date":"2026-03-31","value":25072000000}],"netIncomeHistory":[{"date":"2025-03-31","value":1323000000},{"date":"2025-06-30","value":1532000000},{"date":"2025-09-30","va