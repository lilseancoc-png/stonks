tributes its products and services through brokers and consultants; directly to employers, unions and other groups, or individuals; and private and public exchanges. The company was formerly known as Cigna Corporation and changed its name to The Cigna Group in February 2023. The company was founded in 1792 and is headquartered in Bloomfield, Connecticut.","industry":"Healthcare Plans","sector":"Healthcare","marketCap":73717243904,"trailingPE":2.450277,"forwardPE":8.320899,"pegRatio":0.86,"priceToBook":1.7468846,"priceToSales":0.265273,"profitMargin":2.263,"operatingMargin":5.4780003,"grossMargin":9.149000000000001,"returnOnEquity":16.268998,"returnOnAssets":4.782,"revenueGrowthYoy":4.6,"earningsGrowthYoy":29.099999999999998,"earningsQuarterlyGrowthYoy":25,"debtToEquity":72.805,"currentRatio":0.818,"quickRatio":0.657,"freeCashFlow":6923375104,"operatingCashFlow":8812000256,"totalCash":7852000256,"totalDebt":30900000768,"revenue":277892005888,"dividendYield":2.19,"payoutRatio":5.3600002,"beta":0.313,"fiftyTwoWeekHigh":338.89,"fiftyTwoWeekLow":239.51,"targetMeanPrice":341.5,"targetHighPrice":400,"targetLowPrice":290,"recommendationKey":"buy","numberOfAnalystOpinions":24,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":7.79,"epsEstimate":7.60633,"surprisePct":2.41},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":7.2,"epsEstimate":7.15372,"surprisePct":0.64999997},{"date":"2025-09-30","period":"-3q","epsActual":7.83,"epsEstimate":7.64116,"surprisePct":2.4699999999999998},{"date":"2025-12-31","period":"-2q","epsActual":8.08,"epsEstimate":7.88281,"surprisePct":2.5},{"date":"2026-03-31","period":"-1q","epsActual":7.79,"epsEstimate":7.60633,"surprisePct":2.41}],"revenueHistory":[{"date":"2025-03-31","value":65500000000},{"date":"2025-06-30","value":66942000000},{"date":"2025-09-30","value":69515000000},{"date":"2025-12-31","value":72372000000},{"date":"2026-03-31","value":273168000000}],"grossProfitHistory":[{"date":"2025-03-31","value":636800