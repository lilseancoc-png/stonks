 headquartered in Zurich, Switzerland.","industry":"Banks - Diversified","sector":"Financial Services","marketCap":156121858048,"trailingPE":17.071686,"forwardPE":11.84384,"pegRatio":0.56,"priceToBook":1.6024088,"priceToSales":3.0426586,"profitMargin":17.764,"operatingMargin":31.471002,"grossMargin":0,"returnOnEquity":10.16,"returnOnAssets":0.567,"revenueGrowthYoy":13.8,"earningsGrowthYoy":84.39999999999999,"earningsQuarterlyGrowthYoy":79.7,"debtToEquity":null,"currentRatio":null,"quickRatio":null,"freeCashFlow":null,"operatingCashFlow":null,"totalCash":528411983872,"totalDebt":574302978048,"revenue":51311001600,"dividendYield":2.34,"payoutRatio":32.259998,"beta":0.831,"fiftyTwoWeekHigh":49.36,"fiftyTwoWeekLow":30.36,"targetMeanPrice":48.13333,"targetHighPrice":58.4,"targetLowPrice":42,"recommendationKey":"none","numberOfAnalystOpinions":3,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":0.9506,"epsEstimate":0.82743,"surprisePct":14.89},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":0.8226,"epsEstimate":0.92276,"surprisePct":-10.850000399999999},{"date":"2025-09-30","period":"-3q","epsActual":0.9179,"epsEstimate":0.60424,"surprisePct":51.910000000000004},{"date":"2025-12-31","period":"-2q","epsActual":0.6702,"epsEstimate":0.67459,"surprisePct":-0.64999997},{"date":"2026-03-31","period":"-1q","epsActual":0.9506,"epsEstimate":0.82743,"surprisePct":14.89}],"revenueHistory":[{"date":"2025-03-31","value":11983000000},{"date":"2025-06-30","value":11499000000},{"date":"2025-09-30","value":11938000000},{"date":"2025-12-31","value":12199000000},{"date":"2026-03-31","value":13771000000}],"grossProfitHistory":[],"netIncomeHistory":[{"date":"2025-03-31","value":1692000000},{"date":"2025-06-30","value":2395000000},{"date":"2025-09-30","value":2481000000},{"date":"2025-12-31","value":1199000000},{"date":"2026-03-31","value":3040000000}],"netMarginHistory":[{"date":"2025-03-31","value":14.120003338062254},{"date":"2025-06-30","value":20.82789807809