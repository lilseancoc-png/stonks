ng and manufacturing customer-owned satellites, mission systems engineering, launch procurement, ground station infrastructure, satellite operations, and maintenance, as well as dedicated image tasking capacity on company-owned or customer-owned satellites. It serves agriculture, mapping, energy, forestry, finance, and insurance companies, as well as government agencies. Planet Labs PBC was founded in 2010 and is headquartered in San Francisco, California.","industry":"Aerospace & Defense","sector":"Industrials","marketCap":16547335168,"trailingPE":null,"forwardPE":-2063.5554,"pegRatio":null,"priceToBook":82.61566,"priceToSales":53.772774,"profitMargin":-80.22,"operatingMargin":-30.429000000000002,"grossMargin":56.154996000000004,"returnOnEquity":-78.403,"returnOnAssets":-5.8590002000000005,"revenueGrowthYoy":41.099999999999994,"earningsGrowthYoy":null,"earningsQuarterlyGrowthYoy":null,"debtToEquity":245.437,"currentRatio":1.652,"quickRatio":1.541,"freeCashFlow":233776992,"operatingCashFlow":134362000,"totalCash":640089984,"totalDebt":462480000,"revenue":307727008,"dividendYield":null,"payoutRatio":0,"beta":1.914,"fiftyTwoWeekHigh":51.76,"fiftyTwoWeekLow":3.66,"targetMeanPrice":35.5,"targetHighPrice":50,"targetLowPrice":20,"recommendationKey":"buy","numberOfAnalystOpinions":10,"lastQuarter":{"date":"2026-01-31","period":"-1q","epsActual":0,"epsEstimate":-0.04921,"surprisePct":100},"earningsHistory":[{"date":"2025-04-30","period":"-4q","epsActual":0,"epsEstimate":-0.03516,"surprisePct":100},{"date":"2025-07-31","period":"-3q","epsActual":-0.03,"epsEstimate":-0.04545,"surprisePct":33.990002000000004},{"date":"2025-10-31","period":"-2q","epsActual":0,"epsEstimate":-0.04063,"surprisePct":100},{"date":"2026-01-31","period":"-1q","epsActual":0,"epsEstimate":-0.04921,"surprisePct":100}],"revenueHistory":[{"date":"2025-01-31","value":61554000},{"date":"2025-04-30","value":66265000},{"date":"2025-07-31","value":73386000},{"date":"2025-10-31","value":81254000},{"date":"2026-0