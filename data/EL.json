, duty-free retailers, specialty multi retailers, online pure players, upscale perfumeries and pharmacies, and top-tier salons and spas, as well as direct-to-consumer businesses across freestanding stores, and brand websites and third-party online platforms. The Estée Lauder Companies Inc. was founded in 1946 and is headquartered in New York, New York.","industry":"Household & Personal Products","sector":"Consumer Defensive","marketCap":28549238784,"trailingPE":null,"forwardPE":24.824068,"pegRatio":1.42,"priceToBook":7.149588,"priceToSales":1.924711,"profitMargin":-1.672,"operatingMargin":14.924999999999999,"grossMargin":74.651,"returnOnEquity":-5.949,"returnOnAssets":4.874,"revenueGrowthYoy":4.6,"earningsGrowthYoy":-45.5,"earningsQuarterlyGrowthYoy":-44,"debtToEquity":232.908,"currentRatio":1.268,"quickRatio":0.824,"freeCashFlow":1807624960,"operatingCashFlow":1798000000,"totalCash":3126000128,"totalDebt":9299999744,"revenue":14833000448,"dividendYield":1.79,"payoutRatio":471.42999999999995,"beta":1.211,"fiftyTwoWeekHigh":121.64,"fiftyTwoWeekLow":62.57,"targetMeanPrice":94.65217,"targetHighPrice":125,"targetLowPrice":70,"recommendationKey":"buy","numberOfAnalystOpinions":23,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":0.91,"epsEstimate":0.64907,"surprisePct":40.2},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":0.09,"epsEstimate":0.08905,"surprisePct":1.0699999999999998},{"date":"2025-09-30","period":"-3q","epsActual":0.32,"epsEstimate":0.17594,"surprisePct":81.88},{"date":"2025-12-31","period":"-2q","epsActual":0.89,"epsEstimate":0.83491,"surprisePct":6.6000000000000005},{"date":"2026-03-31","period":"-1q","epsActual":0.91,"epsEstimate":0.64907,"surprisePct":40.2}],"revenueHistory":[{"date":"2025-03-31","value":3550000000},{"date":"2025-06-30","value":3411000000},{"date":"2025-09-30","value":3481000000},{"date":"2025-12-31","value":4229000000},{"date":"2026-03-31","value":3712000000}],"grossProfitHistory":[{"date":"2025-03-31","