0.4798025653076171,"oi":4,"v":1}]}},"technicals":{"asOfClose":91.74,"bars":151,"rsi":65.51,"macd":{"line":1.7216,"signal":0.8228,"hist":0.8988},"sr":{"s20":75.22,"r20":91.88,"s50":66.22,"r50":91.99},"volRegime":{"rv30":0.5047,"rv30Pctile":50,"samples":121},"volume":{"today":551826,"avg20":3850300,"rvol":0.14,"priceMove1dPct":5.93,"conviction":"weak"}},"fundamentals":{"name":"The Estée Lauder Companies Inc.","longBusinessSummary":"The Estée Lauder Companies Inc. manufactures, markets, and sells skin care, makeup, fragrance, and hair care products worldwide. The company offers skin care products, including moisturizers, serums, cleansers, toners, eye care, body care, exfoliators, acne care and oil correctors, facial masks, and sun care products; and makeup products, such as foundations, powders, concealers and setting sprays, lipsticks, lip liners and lip glosses, mascaras, and eyeshadows and eyeliners, as well as compacts, brushes, and other makeup tools. It also provides fragrance products in various forms comprising parfum, eau de parfum, eau de toilette, eau de cologne, and body spray, as well as lotions, creams, powders, candles and soaps; and hair care products, including shampoos, conditioners, styling products, treatment, finishing sprays, and hair colour products, as well as sells ancillary products and services. The company offers its products under the La Mer, Jo Malone London, TOM FORD, AERIN Beauty, Le Labo, Editions de Parfums Frédéric Malle, KILIAN PARIS, BALMAIN Beauty, Estée Lauder, Clinique, M·A·C, The Ordinary, Aveda, Bobbi Brown Cosmetics, Too Faced, Dr.Jart+, Bumble and bumble, Editions de Parfums Frédéric Malle, Smashbox, Darphin Paris, Lab Series, NIOD, Aramis, and GLAMGLOW brands. It sells its products through department stores, duty-free retailers, specialty multi retailers, online pure players, upscale perfumeries and pharmacies, and top-tier salons and spas, as well as direct-to-consumer businesses across freestanding stores, and brand websites and third-party online platforms. The Estée Lauder Companies Inc. was founded in 1946 and is headquartered in New York, New York.","industry":"Household & Personal Products","sector":"Consumer Defensive","marketCap":33189257216,"trailingPE":null,"forwardPE":28.858646,"pegRatio":1.42,"priceToBook":8.311588,"priceToSales":2.2375283,"profitMargin":-1.672,"operatingMargin":14.924999999999999,"grossMargin":74.651,"returnOnEquity":-5.949,"returnOnAssets":4.874,"revenueGrowthYoy":4.6,"earningsGrowthYoy":-45.5,"earningsQuarterlyGrowthYoy":-44,"debtToEquity":232.908,"currentRatio":1.268,"quickRatio":0.824,"freeCashFlow":1807624960,"operatingCashFlow":1798000000,"totalCash":3126000128,"totalDebt":9299999744,"revenue":14833000448,"dividendYield":1.6199999999999999,"payoutRatio":471.42999999999995,"beta":1.211,"fiftyTwoWeekHigh":121.64,"fiftyTwoWeekLow":64.83,"targetMeanPrice":95.43478,"targetHighPrice":125,"targetLowPrice":70,"recommendationKey":"buy","numberOfAnalystOpinions":23,"lastQuarter":{"date":"2026-03-31","period":"-1q","epsActual":0.91,"epsEstimate":0.64907,"surprisePct":40.2},"earningsHistory":[{"date":"2025-06-30","period":"-4q","epsActual":0.09,"epsEstimate":0.08905,"surprisePct":1.0699999999999998},{"date":"2025-09-30","period":"-3q","epsActual":0.32,"epsEstimate":0.17594,"surprisePct":81.88},{"date":"2025-12-31","period":"-2q","epsActual":0.89,"epsEstimate":0.83491,"surprisePct":6.6000000000000005},{"date":"2026-03-31","period":"-1q","epsActual":0.91,"epsEstimate":0.64907,"surprisePct":40.2}],"revenueHistory":[{"date":"2025-03-31","value":3550000000},{"date":"2025-06-30","value":3411000000},{"date":"2025-09-30","value":3481000000},{"date":"2025-12-31","value":4229000000},{"date":"2026-03-31","value":3712000000}],"grossProfitHistory":[{"date":"2025-03-31","value":2661000000},{"date":"2025-06-30","value":2456000000},{"date":"2025-09-30","value":2554000000},{"date":"2025-12-31","value":3235000000},{"date":"2026-03-31","value":2836000000}],"netIncomeHistory":[{"