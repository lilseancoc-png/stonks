{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/quote.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
