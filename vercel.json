{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'No build step — files are committed by the daily-build workflow.'",
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/quote.js": {
      "maxDuration": 10
    },
    "api/chain.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/data/unusual(.*)\\.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=60, stale-while-revalidate=3600" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
